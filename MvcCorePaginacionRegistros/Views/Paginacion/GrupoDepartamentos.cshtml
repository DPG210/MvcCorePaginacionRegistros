@model List<Departamento>
@{
    int numRegistros = (int)ViewData["NUMEROREGISTROS"];

    int numPagina = 1;
}

<h1>Paginacion Grupal Departamentos</h1>

<hr />


<hr />
<div class="pagination-container">
    @for (int i = 1; i <= numRegistros; i += 2)
    {

        <a asp-controller="Paginacion" asp-action="GrupoDepartamentos" asp-route-posicion=@i"
           class="btn btn-info">
            Página @numPagina
        </a>

        numPagina++;
    }
</div>

<table class="table table-warning">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Localidad</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Departamento dept in Model)
        {
            <tr>
                <td>@dept.IdDepartamento</td>
                <td>@dept.Nombre</td>
                <td>@dept.Localidad</td>
            </tr>
        }
    </tbody>
</table>

