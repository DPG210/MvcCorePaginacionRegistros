@model List<Empleado>
@{
    int numRegistros = (int)ViewData["REGISTROS"];

    int numPagina = 1;
}

<h1>Paginacion Grupal Departamentos</h1>

<hr />


<hr />
<div class="pagination-container">
    @for (int i = 1; i <= numRegistros; i += 3)
    {

        <a asp-controller="Paginacion" asp-action="GrupoEmpleados" asp-route-posicion=@i"
           class="btn btn-info">
            Página @numPagina
        </a>

        numPagina++;
    }
</div>

<table class="table table-warning">
    <thead>
        <tr>
            <th>IdDept</th>
            <th>IdEmpleado</th>
            <th>Apellido</th>
            <th>Oficio</th>
            <th>Salario</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Empleado emp in Model)
        {
            <tr>
                <td>@emp.IdDepartamento</td>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                
            </tr>
        }
    </tbody>
</table>

